{
  "_comment": "MCP client configuration for VS Code, Claude Code, Cursor, Windsurf and other editors. Copy this file to .mcp.json and adjust the URL and token to match your zabbix-mcp-server instance. This file is not used by the server itself.",
  "mcpServers": {
    "zabbix": {
      "type": "http",
      "url": "http://127.0.0.1:8080/mcp",
      "headers": {
        "Authorization": "Bearer your-auth-token-here"
      }
    }
  }
}
